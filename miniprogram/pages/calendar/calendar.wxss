/* pages/calendar/calendar.wxss */

.calendar-container {
  min-height: 100vh;
  background: var(--primary-bg);
}

.month-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: var(--white);
}

.nav-btn {
  font-size: 26rpx;
  color: var(--primary);
  padding: 8rpx 16rpx;
}

.month-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.calendar-grid {
  background: var(--white);
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.week-header {
  display: flex;
  margin-bottom: 16rpx;
}

.week-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-hint);
}

.days-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-item {
  width: calc(100% / 7);
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.day-today .day-text {
  color: var(--primary);
  font-weight: bold;
}

.day-has-order {
  background: var(--primary);
  border-radius: 12rpx;
}

.day-has-order .day-text {
  color: var(--white);
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  background: var(--white);
  border-radius: 50%;
  margin-top: 4rpx;
}

.date-detail {
  background: var(--white);
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.detail-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.upload-btn {
  background: var(--primary);
  color: var(--white);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.detail-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.order-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.order-tag {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--primary-bg);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-item {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
  background: var(--primary-light);
}

.detail-empty {
  text-align: center;
  padding: 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}