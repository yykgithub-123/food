/* pages/manageCategories/manageCategories.wxss */
.manage-categories-container {
  padding: 16px;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.categories-list {
  margin-bottom: 80px;
}

.category-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-text {
  color: #999;
  font-size: 14px;
}

.category-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.category-sort-btns {
  display: flex;
  flex-direction: column;
  margin-right: 12px;
  gap: 4px;
}

.sort-btn {
  width: 28px;
  height: 28px;
  background-color: #f5f5f5;
  border-radius: 6px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 16px;
  color: #666;
}

.sort-btn-disabled {
  color: #ccc;
  pointer-events: none;
}

.category-content {
  flex: 1;
}

.category-name {
  font-size: 16px;
  font-weight: 500;
  color: #333;
}

.category-count {
  font-size: 12px;
  color: #999;
  margin-top: 4px;
}

.category-actions {
  display: flex;
  gap: 8px;
}

.action-btn {
  padding: 6px 12px;
  border-radius: 6px;
  font-size: 12px;
}

.action-edit {
  background-color: #FF6B9D;
  color: #fff;
}

.action-delete {
  background-color: #fff;
  color: #FF6B9D;
  border: 1px solid #FF6B9D;
}

/* 添加区域 */
.add-section {
  position: fixed;
  bottom: 16px;
  left: 16px;
  right: 16px;
  display: flex;
  gap: 12px;
  background-color: #fff;
  padding: 12px;
  border-radius: 12px;
}

.add-input {
  flex: 1;
  height: 40px;
  background-color: #f5f5f5;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
}

.add-btn {
  width: 80px;
  height: 40px;
  background-color: #FF6B9D;
  color: #fff;
  border-radius: 8px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 14px;
}

.add-btn-disabled {
  background-color: #ccc;
}

/* 编辑弹窗 */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.edit-modal-content {
  width: 80%;
  background-color: #fff;
  border-radius: 16px;
  overflow: hidden;
}

.edit-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #eee;
}

.edit-modal-title {
  font-size: 18px;
  font-weight: 500;
}

.edit-modal-close {
  font-size: 24px;
  color: #999;
}

.edit-modal-body {
  padding: 16px;
}

.edit-field {
  margin-bottom: 16px;
}

.edit-label {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
}

.edit-input {
  width: 100%;
  height: 40px;
  background-color: #f5f5f5;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
}

.edit-modal-footer {
  display: flex;
  border-top: 1px solid #eee;
}

.edit-cancel {
  flex: 1;
  height: 48px;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #666;
}

.edit-save {
  flex: 1;
  height: 48px;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #FF6B9D;
  color: #fff;
}